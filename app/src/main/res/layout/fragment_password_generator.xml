<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vx_background"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding_h"
    tools:context="com.vaultx.ui.generator.PasswordGeneratorFragment">

    <!-- Top Bar with Back -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="@dimen/icon_lg"
            android:layout_height="@dimen/icon_lg"
            android:layout_gravity="start|center_vertical"
            android:src="@drawable/ic_chevron_right"
            android:rotation="180"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            style="@style/VaultX.Heading.Small"
            android:text="PASSWORD GENERATOR" />
    </FrameLayout>

    <!-- Generated Password Display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xxl"
        android:background="@drawable/bg_input"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_lg"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvGeneratedPassword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            tools:text="xQu8!kz#9"
            android:textColor="@color/vx_cyan"
            android:textSize="20sp"
            android:textAlignment="center"
            android:letterSpacing="0.1" />

        <ImageView
            android:id="@+id/btnRegenerate"
            android:layout_width="@dimen/icon_md"
            android:layout_height="@dimen/icon_md"
            android:src="@drawable/ic_refresh"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginEnd="@dimen/spacing_sm" />

        <ImageView
            android:id="@+id/btnCopy"
            android:layout_width="@dimen/icon_md"
            android:layout_height="@dimen/icon_md"
            android:src="@drawable/ic_copy"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- Security Level Indicator -->
    <TextView
        android:id="@+id/tvStrength"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        style="@style/VaultX.Label"
        android:textColor="@color/vx_green"
        android:textAlignment="center"
        tools:text="STRENGTH: STRONG" />

    <!-- Configuration Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xl"
        android:background="@drawable/bg_glass_card"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Length Slider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LENGTH"
                style="@style/VaultX.Label" />
            <TextView
                android:id="@+id/tvLengthValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="16"
                style="@style/VaultX.Label"
                android:textColor="@color/vx_cyan" />
        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderLength"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="8"
            android:valueTo="32"
            android:value="16"
            android:stepSize="1"
            app:thumbColor="@color/vx_cyan"
            app:trackColorActive="@color/vx_cyan"
            app:trackColorInactive="@color/vx_surface_container_highest" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="@dimen/spacing_sm"
            android:background="@color/vx_divider" />

        <!-- Toggles -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swUppercase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="UPPERCASE (A-Z)"
            style="@style/VaultX.Label"
            android:paddingVertical="@dimen/spacing_sm"
            android:checked="true"
            app:thumbTint="@color/vx_cyan"
            app:trackTint="@color/vx_surface_container" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swLowercase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LOWERCASE (a-z)"
            style="@style/VaultX.Label"
            android:paddingVertical="@dimen/spacing_sm"
            android:checked="true"
            app:thumbTint="@color/vx_cyan"
            app:trackTint="@color/vx_surface_container" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swNumbers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NUMBERS (0-9)"
            style="@style/VaultX.Label"
            android:paddingVertical="@dimen/spacing_sm"
            android:checked="true"
            app:thumbTint="@color/vx_cyan"
            app:trackTint="@color/vx_surface_container" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swSymbols"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SYMBOLS (!@#$)"
            style="@style/VaultX.Label"
            android:paddingVertical="@dimen/spacing_sm"
            android:checked="true"
            app:thumbTint="@color/vx_cyan"
            app:trackTint="@color/vx_surface_container" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Action Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUsePassword"
        style="@style/VaultX.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:text="USE SETTING"
        android:background="@drawable/bg_gradient_button" />

</LinearLayout>

