<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vx_background"
    tools:context="com.vaultx.ui.detail.PasswordDetailFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/screen_padding_h">

            <!-- Top Bar with Back, Detail Text, Delete -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="@dimen/icon_lg"
                    android:layout_height="@dimen/icon_lg"
                    android:layout_gravity="start|center_vertical"
                    android:src="@drawable/ic_chevron_right"
                    android:rotation="180"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    style="@style/VaultX.Heading.Small"
                    android:text="CREDENTIAL DETAIL" />

                <ImageView
                    android:id="@+id/btnDelete"
                    android:layout_width="@dimen/icon_lg"
                    android:layout_height="@dimen/icon_lg"
                    android:layout_gravity="end|center_vertical"
                    android:src="@drawable/ic_delete"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp" />
            </FrameLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_xl"
                android:indeterminateTint="@color/vx_cyan" />

            <LinearLayout
                android:id="@+id/contentLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="@dimen/spacing_xl">

                <!-- Header block -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_input">
                        <ImageView
                            android:id="@+id/ivCategoryIcon"
                            android:layout_width="@dimen/icon_lg"
                            android:layout_height="@dimen/icon_lg"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_social" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        style="@style/VaultX.Heading.Medium"
                        tools:text="GitHub" />

                    <TextView
                        android:id="@+id/tvCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        style="@style/VaultX.Label"
                        android:textColor="@color/vx_cyan"
                        tools:text="DEVELOPMENT" />
                </LinearLayout>

                <!-- Detail Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xxl"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_xl">

                    <!-- Username -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="USERNAME"
                        style="@style/VaultX.Label.Muted" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:id="@+id/tvUsername"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/vx_text_primary"
                            android:textSize="16sp"
                            tools:text="alex@example.com" />
                        <ImageView
                            android:id="@+id/btnCopyUsername"
                            android:layout_width="@dimen/icon_md"
                            android:layout_height="@dimen/icon_md"
                            android:src="@drawable/ic_copy"
                            android:background="?attr/selectableItemBackgroundBorderless" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/spacing_md"
                        android:background="@color/vx_divider" />

                    <!-- Password -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PASSWORD"
                        style="@style/VaultX.Label.Muted" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvPassword"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/vx_cyan"
                            android:textSize="18sp"
                            android:letterSpacing="0.1"
                            android:text="••••••••••" />

                        <ImageView
                            android:id="@+id/btnTogglePassword"
                            android:layout_width="@dimen/icon_md"
                            android:layout_height="@dimen/icon_md"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:src="@drawable/ic_eye"
                            android:background="?attr/selectableItemBackgroundBorderless" />

                        <ImageView
                            android:id="@+id/btnCopyPassword"
                            android:layout_width="@dimen/icon_md"
                            android:layout_height="@dimen/icon_md"
                            android:src="@drawable/ic_copy"
                            android:background="?attr/selectableItemBackgroundBorderless" />
                    </LinearLayout>

                    <!-- URL if exists -->
                    <LinearLayout
                        android:id="@+id/layoutUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="@dimen/spacing_md"
                            android:background="@color/vx_divider" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="URL"
                            style="@style/VaultX.Label.Muted" />
                            
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:id="@+id/tvUrl"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="@color/vx_cyan"
                                android:textSize="14sp"
                                tools:text="https://github.com" />
                            <ImageView
                                android:id="@+id/btnOpenUrl"
                                android:layout_width="@dimen/icon_md"
                                android:layout_height="@dimen/icon_md"
                                android:src="@drawable/ic_external_link"
                                android:background="?attr/selectableItemBackgroundBorderless" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Notes if exists -->
                    <LinearLayout
                        android:id="@+id/layoutNotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="@dimen/spacing_md"
                            android:background="@color/vx_divider" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NOTES"
                            style="@style/VaultX.Label.Muted" />
                            
                        <TextView
                            android:id="@+id/tvNotes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:textColor="@color/vx_text_muted"
                            android:textSize="14sp"
                            tools:text="API Keys inside..." />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- FAB Edit -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabEdit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/fab_margin"
        android:contentDescription="Edit"
        app:srcCompat="@drawable/ic_edit"
        app:tint="@color/white"
        app:backgroundTint="@color/vx_cyan" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>

